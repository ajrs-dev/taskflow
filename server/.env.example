# Port the API listens on
PORT=4000

# Secret used to sign JWTs — CHANGE THIS in any real deployment
JWT_SECRET=super-secret-dev-key-change-me

# How long an access token stays valid (zeit/ms format)
JWT_EXPIRES_IN=7d

# Path to the SQLite database file (use ":memory:" for an ephemeral DB)
DB_PATH=taskflow.db

# Origin allowed by CORS (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173
